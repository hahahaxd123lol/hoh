# Copy this to .env and fill in your values
# Restart server after changes

# Server config
PORT=3000
DATA_DIR=./data

# Security Discord webhook (receives password + login attempts)
SECURITY_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_SECURITY_WEBHOOK_HERE

# Order Discord webhook (receives orders - can be same as security)
ORDER_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ORDER_WEBHOOK_HERE

# Optional: GIF shown on failed login attempts
ATTEMPT_GIF_URL=https://example.com/fail.gif

